# WCF Planner — environment variable reference (NAMES ONLY, no secret values).
# Copy to .env / .env.test / .env.test.local / .env.prod.local and fill values
# from the escrowed secret manager. NEVER commit a file containing real values
# (.gitignore ignores .env and .env.* except this .env.example).
#
# "secret" = must come from the secret manager and never be exposed client-side.
# VITE_* values are embedded in the client bundle and are PUBLIC by design
# (the anon key is RLS-gated; do not put a service-role key in any VITE_* var).

# ── Client / build-time (Vite) — PUBLIC, embedded in the bundle ──────────────
# Production falls back to hardcoded literals in src/lib/supabase.js when unset.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Test project + CI (Playwright / Vitest / GitHub Actions) ─────────────────
# These point at the TEST Supabase project only — never PROD.
WCF_TEST_DATABASE=            # set to 1 to satisfy the assertTestDatabase guard
SUPABASE_SERVICE_ROLE_KEY=    # secret — TEST project service role (DB reset/seed)
VITE_TEST_ADMIN_EMAIL=        # TEST admin login used by e2e
VITE_TEST_ADMIN_PASSWORD=     # secret — TEST admin password

# ── Node admin scripts (scripts/) — run locally with elevated access ─────────
SUPABASE_URL=                 # target project REST URL for a script run
PROD_SERVICE_ROLE_JWT=        # secret — PROD service role for one-off PROD scripts
# Legacy Podio import (scripts/import_production_legacy_events_*) — only needed
# if re-running the historical backfill; otherwise leave unset.
PODIO_CLIENT_ID=
PODIO_CLIENT_SECRET=          # secret
PODIO_USERNAME=
PODIO_PASSWORD=               # secret
PODIO_SPACE_NAME=
# Weather backfill/label script config (non-secret).
WCF_FARM_WEATHER_LABEL=
WCF_FARM_WEATHER_LAT=
WCF_FARM_WEATHER_LON=

# ── Supabase Edge Function secrets (set via `supabase secrets set`, NOT here) ─
# Listed for escrow/inventory only. tasks-cron, tasks-summary, and
# rapid-processor (in supabase-functions/) read these from the function runtime.
# SUPABASE_URL=               # provided by the Supabase function runtime
# SUPABASE_ANON_KEY=          # provided by the Supabase function runtime
# SERVICE_ROLE_KEY=           # secret — function service role
# TASKS_CRON_SECRET=          # secret — shared secret gating cron/summary invocation
# RESEND_API_KEY=             # secret — Resend email API key (rapid-processor sender)
